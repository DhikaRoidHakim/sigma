# =========================================================
# SIGMA - Environment variables for docker-compose
# Copy this file to `.env` and adjust the values.
# =========================================================

# ---------- MongoDB ----------
MONGO_ROOT_USER=sigma
MONGO_ROOT_PASSWORD=sigma_secret
MONGO_PORT=27017
DB_NAME=sigma

# Full connection string used by the backend.
# When Mongo runs inside compose, use hostname "mongo".
MONGO_URL=mongodb://sigma:sigma_secret@mongo:27017/?authSource=admin

# ---------- Backend (FastAPI) ----------
# Allowed origins for CORS (comma separated, no spaces).
CORS_ORIGINS=http://localhost:8080,http://localhost:3000

# Secret used to sign JWT tokens. GENERATE A LONG RANDOM STRING for production
# (e.g. `openssl rand -hex 32`).
JWT_SECRET=change-me-to-a-long-random-secret-string

# Default admin (seeded on first startup).
ADMIN_EMAIL=admin@sigma.co.id
ADMIN_PASSWORD=Sigma@2026

# Public URL used inside QR codes (must point to the deployed frontend).
FRONTEND_URL=http://localhost:8080

# Port on the host that maps to backend:8001 (for debugging).
BACKEND_PORT=8001

# ---------- Frontend ----------
# Leave empty for same-origin (Nginx proxies /api to backend).
# For a separate backend host, set e.g. https://api.sigma.example.com
REACT_APP_BACKEND_URL=

# Port on the host that serves the frontend.
FRONTEND_PORT=8080
